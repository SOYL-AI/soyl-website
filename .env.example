# Backend agent (FastAPI: Asterisk + LangGraph + RAG). For local dev, point at
# your locally-running agent. In prod, set to the Railway/hosted URL.
AGENT_API_URL=http://localhost:8000

# Upstash Redis — powers Butler demo rate limits (text + audio + session cap).
# Get these from https://console.upstash.com. If unset, the limiters fall back
# to no-op so dev works without the secrets.
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# Sanity CMS — powers the /library section and the Studio at /studio.
# Create a free project at https://sanity.io/manage, then paste the project
# ID below. Leave NEXT_PUBLIC_SANITY_PROJECT_ID empty during local dev to
# fall back to the mockData seed in src/lib/mockData.ts. Once Sanity is
# provisioned, invite CEO + CTO as Editors and they can publish from /studio.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
# Optional: only needed for draft preview / privileged reads. Generate at
# https://sanity.io/manage → Project → API → Tokens (viewer role is enough).
SANITY_API_TOKEN=
